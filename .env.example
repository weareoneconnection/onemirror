# Production-ready Postgres setup
# For Vercel + Neon/Supabase/Railway, use your pooled connection string here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Optional but recommended for Prisma migrations / direct connections.
# If your provider gives you a non-pooled direct URL, put it here.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Public app URL used for metadata and share links
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Optional OneAI integration
ONEAI_API_BASE_URL="https://your-oneai-api.com"
ONEAI_API_KEY=""
ONEAI_MODEL="oneai-mirror-v1"
ONEAI_TIMEOUT_MS="12000"
